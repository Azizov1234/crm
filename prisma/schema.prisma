generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
  STAFF
}

enum Status {
  ACTIVE
  INACTIVE
  ARCHIVED
  DELETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum SmsStatus {
  PENDING
  SENT
  FAILED
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  ATTENDANCE_MARK
  ROLE_UPDATE
  ASSIGN
  UNASSIGN
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  phone     String?
  email     String?
  logoUrl   String?
  website   String?
  status    Status    @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  branches         Branch[]
  users            User[]
  adminProfiles    AdminProfile[]
  teacherProfiles  TeacherProfile[]
  studentProfiles  StudentProfile[]
  parentProfiles   ParentProfile[]
  staffProfiles    StaffProfile[]
  courses          Course[]
  rooms            Room[]
  groups           Group[]
  timetables       Timetable[]
  attendances      Attendance[]
  staffAttendances StaffAttendance[]
  ratings          Rating[]
  payments         Payment[]
  paymentHistories PaymentHistory[]
  expenses         Expense[]
  settings         OrganizationSetting?
  tariffPlans      TariffPlan[]
  subscriptions    Subscription[]
  smsLogs          SmsLog[]
  smsTemplates     SmsTemplate[]
  actionLogs       ActionLog[]
  errorLogs        ErrorLog[]

  @@index([status])
}

model OrganizationSetting {
  id             String    @id @default(cuid())
  organizationId String    @unique
  timezone       String    @default("Asia/Tashkent")
  locale         String    @default("uz-UZ")
  currency       String    @default("UZS")
  primaryColor   String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([status])
}

model Branch {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  code           String
  phone          String?
  email          String?
  address        String?
  logoUrl        String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  users           User[]
  adminProfiles   AdminProfile[]
  teacherProfiles TeacherProfile[]
  studentProfiles StudentProfile[]
  parentProfiles  ParentProfile[]
  staffProfiles   StaffProfile[]

  courses          Course[]
  rooms            Room[]
  groups           Group[]
  timetables       Timetable[]
  attendances      Attendance[]
  staffAttendances StaffAttendance[]
  ratings          Rating[]
  payments         Payment[]
  paymentHistories PaymentHistory[]
  expenses         Expense[]
  smsLogs          SmsLog[]
  smsTemplates     SmsTemplate[]
  actionLogs       ActionLog[]
  errorLogs        ErrorLog[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
}

model User {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String?
  role           UserRole
  firstName      String
  lastName       String
  phone          String?
  email          String?   @unique
  passwordHash   String
  avatarUrl      String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])

  adminProfile   AdminProfile?
  teacherProfile TeacherProfile?
  studentProfile StudentProfile?
  parentProfile  ParentProfile?
  staffProfile   StaffProfile?

  markedAttendances        Attendance[]      @relation("AttendanceMarker")
  markedStaffAttendances   StaffAttendance[] @relation("StaffAttendanceMarker")
  receivedPaymentHistories PaymentHistory[]  @relation("PaymentHistoryReceiver")
  smsLogs                  SmsLog[]          @relation("SmsSender")
  actionLogs               ActionLog[]
  errorLogs                ErrorLog[]

  @@index([organizationId, branchId, role, status])
}

model AdminProfile {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String?
  userId         String    @unique
  notes          String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, branchId, status])
}

model TeacherProfile {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  userId         String    @unique
  specialty      String?
  salary         Decimal?  @db.Decimal(12, 2)
  hiredAt        DateTime?
  bio            String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  groups       Group[]
  ratingsGiven Rating[] @relation("RatingTeacher")

  @@index([organizationId, branchId, status])
}

model StudentProfile {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  userId         String    @unique
  studentNo      String?
  birthDate      DateTime?
  gender         Gender?
  joinedAt       DateTime?
  address        String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  parentLinks ParentStudent[]
  groupLinks  GroupStudent[]
  attendances Attendance[]
  ratings     Rating[]
  payments    Payment[]

  @@unique([organizationId, studentNo])
  @@index([organizationId, branchId, status])
}

model ParentProfile {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  userId         String    @unique
  occupation     String?
  address        String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  studentLinks ParentStudent[]

  @@index([organizationId, branchId, status])
}

model StaffProfile {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  userId         String    @unique
  position       String?
  salary         Decimal?  @db.Decimal(12, 2)
  hiredAt        DateTime?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  attendances StaffAttendance[]

  @@index([organizationId, branchId, status])
}

model ParentStudent {
  id           String    @id @default(cuid())
  parentId     String
  studentId    String
  relationType String?
  status       Status    @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  parent  ParentProfile  @relation(fields: [parentId], references: [id])
  student StudentProfile @relation(fields: [studentId], references: [id])

  @@unique([parentId, studentId])
  @@index([status])
}

model GroupStudent {
  id        String    @id @default(cuid())
  groupId   String
  studentId String
  joinedAt  DateTime  @default(now())
  status    Status    @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  group   Group          @relation(fields: [groupId], references: [id])
  student StudentProfile @relation(fields: [studentId], references: [id])

  @@unique([groupId, studentId])
  @@index([status])
}

model Course {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  name           String
  code           String?
  description    String?
  price          Decimal   @db.Decimal(12, 2)
  durationMonth  Int?
  coverUrl       String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])

  groups Group[]

  @@index([organizationId, branchId, status])
}

model Room {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  name           String
  capacity       Int
  floor          String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])

  groups     Group[]
  timetables Timetable[]

  @@unique([branchId, name])
  @@index([organizationId, branchId, status])
}

model Group {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  courseId       String
  teacherId      String?
  roomId         String?
  name           String
  code           String?
  capacity       Int
  price          Decimal?  @db.Decimal(12, 2)
  startDate      DateTime?
  endDate        DateTime?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id])
  branch       Branch          @relation(fields: [branchId], references: [id])
  course       Course          @relation(fields: [courseId], references: [id])
  teacher      TeacherProfile? @relation(fields: [teacherId], references: [id])
  room         Room?           @relation(fields: [roomId], references: [id])

  students    GroupStudent[]
  timetables  Timetable[]
  attendances Attendance[]
  ratings     Rating[]
  payments    Payment[]

  @@index([organizationId, branchId, status])
}

model Timetable {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  groupId        String
  roomId         String
  dayOfWeek      Int
  startTime      String
  endTime        String
  validFrom      DateTime?
  validTo        DateTime?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  group        Group        @relation(fields: [groupId], references: [id])
  room         Room         @relation(fields: [roomId], references: [id])

  @@index([organizationId, branchId, dayOfWeek, status])
}

model Attendance {
  id               String           @id @default(cuid())
  organizationId   String
  branchId         String
  groupId          String
  studentId        String
  date             DateTime
  attendanceStatus AttendanceStatus
  markedById       String?
  note             String?
  status           Status           @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id])
  branch       Branch         @relation(fields: [branchId], references: [id])
  group        Group          @relation(fields: [groupId], references: [id])
  student      StudentProfile @relation(fields: [studentId], references: [id])
  markedBy     User?          @relation("AttendanceMarker", fields: [markedById], references: [id])

  @@unique([studentId, groupId, date])
  @@index([organizationId, branchId, date, status])
}

model StaffAttendance {
  id               String           @id @default(cuid())
  organizationId   String
  branchId         String
  staffId          String
  date             DateTime
  attendanceStatus AttendanceStatus
  checkIn          DateTime?
  checkOut         DateTime?
  markedById       String?
  note             String?
  status           Status           @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  staff        StaffProfile @relation(fields: [staffId], references: [id])
  markedBy     User?        @relation("StaffAttendanceMarker", fields: [markedById], references: [id])

  @@unique([staffId, date])
  @@index([organizationId, branchId, date, status])
}

model Rating {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  groupId        String
  studentId      String
  teacherId      String?
  score          Decimal   @db.Decimal(5, 2)
  comment        String?
  ratedAt        DateTime  @default(now())
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id])
  branch       Branch          @relation(fields: [branchId], references: [id])
  group        Group           @relation(fields: [groupId], references: [id])
  student      StudentProfile  @relation(fields: [studentId], references: [id])
  teacher      TeacherProfile? @relation("RatingTeacher", fields: [teacherId], references: [id])

  @@index([organizationId, branchId, ratedAt, status])
}

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  branchId       String
  studentId      String
  groupId        String?
  month          Int
  year           Int
  amount         Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(PENDING)
  dueDate        DateTime?
  note           String?
  fileUrl        String?
  status         Status        @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id])
  branch       Branch         @relation(fields: [branchId], references: [id])
  student      StudentProfile @relation(fields: [studentId], references: [id])
  group        Group?         @relation(fields: [groupId], references: [id])

  histories PaymentHistory[]

  @@index([organizationId, branchId, paymentStatus, status])
}

model PaymentHistory {
  id             String        @id @default(cuid())
  organizationId String
  branchId       String
  paymentId      String
  amount         Decimal       @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(PAID)
  method         String
  referenceNo    String?
  receivedById   String?
  note           String?
  paidAt         DateTime      @default(now())
  status         Status        @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  payment      Payment      @relation(fields: [paymentId], references: [id])
  receivedBy   User?        @relation("PaymentHistoryReceiver", fields: [receivedById], references: [id])

  @@index([organizationId, branchId, paidAt, status])
}

model Expense {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  title          String
  category       String
  amount         Decimal   @db.Decimal(12, 2)
  expenseDate    DateTime
  paidBy         String?
  note           String?
  fileUrl        String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])

  @@index([organizationId, branchId, expenseDate, status])
}

model TariffPlan {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  price          Decimal   @db.Decimal(12, 2)
  durationDays   Int
  studentLimit   Int
  branchLimit    Int
  features       Json?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization  Organization   @relation(fields: [organizationId], references: [id])
  subscriptions Subscription[]

  @@index([organizationId, status])
}

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String
  tariffPlanId       String
  startDate          DateTime
  endDate            DateTime
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  autoRenew          Boolean            @default(false)
  status             Status             @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  tariffPlan   TariffPlan   @relation(fields: [tariffPlanId], references: [id])

  @@index([organizationId, subscriptionStatus, status])
}

model SmsLog {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  senderId       String?
  recipientPhone String
  message        String
  provider       String?
  externalId     String?
  smsStatus      SmsStatus @default(PENDING)
  errorMessage   String?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  sender       User?        @relation("SmsSender", fields: [senderId], references: [id])

  @@index([organizationId, branchId, smsStatus, status])
}

model SmsTemplate {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  name           String
  body           String
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])

  @@index([organizationId, branchId, status])
}

model ActionLog {
  id             String     @id @default(cuid())
  organizationId String
  userId         String?
  branchId       String?
  actionType     ActionType
  entityType     String
  entityId       String?
  description    String
  oldData        Json?
  newData        Json?
  ipAddress      String?
  userAgent      String?
  status         Status     @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])

  @@index([organizationId, branchId, actionType, createdAt, status])
}

model ErrorLog {
  id             String    @id @default(cuid())
  organizationId String
  userId         String?
  branchId       String?
  message        String
  stack          String?
  path           String?
  method         String?
  statusCode     Int?
  ipAddress      String?
  userAgent      String?
  meta           Json?
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])

  @@index([organizationId, branchId, statusCode, createdAt, status])
}
